generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Activity {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  requiredDriverLicense  String?
  imageUrl               String?
  requiredDocumentations ActivityDocumentation[]
  documentationFiles     DocumentationFile[]
  applications           application[]           @relation("ActivityApplications")
}

model Documentation {
  id                 String                  @id @default(cuid())
  name               String                  @unique
  isGlobal           Boolean                 @default(false)
  activities         ActivityDocumentation[]
  documentationFiles DocumentationFile[]
}

model ActivityDocumentation {
  id              String        @id @default(cuid())
  activityId      String
  documentationId String
  quantity        Int?
  isSpecific      Boolean       @default(false)
  notes           String?
  activity        Activity      @relation(fields: [activityId], references: [id])
  documentation   Documentation @relation(fields: [documentationId], references: [id])

  @@unique([activityId, documentationId])
  @@index([activityId, documentationId])
}

model Zone {
  id           String        @id @default(cuid())
  name         String
  applications application[] @relation("ZoneApplications")
}

model Company {
  id          String        @id @default(cuid())
  name        String?
  phone       String        @default("")
  rut         String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  city        String?
  status      Boolean       @default(true)
  url         String?
  logoUrl      String?
  Contract     Contract[]
  User         User[]
  application  application[]
  subcontracts Subcontract[] @relation("SubcontractCompany")
}

model Contract {
  id              String            @id @default(cuid())
  finalDate       DateTime
  deletedAt       DateTime?
  companyId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  useracId        String
  contractName    String
  contractNumber  String            @unique
  initialDate     DateTime
  Company         Company           @relation(fields: [companyId], references: [id])
  userAc          User              @relation(fields: [useracId], references: [id])
  ReassignmentLog ReassignmentLog[]
  application     application[]
  subcontracts    Subcontract[]

  @@index([companyId])
  @@index([useracId])
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  password              String?
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  displayName           String
  name                  String
  lastName              String
  middleName            String?
  userName              String
  secondLastName        String?
  category              String
  companyId             String?
  deletedLogic          Boolean?           @default(false)
  phoneNumber           String
  run                   String             @unique
  adminContractorId     String?
  isActive              Boolean            @default(true)
  lastActive            DateTime?
  accounts              Account[]
  applicationAudits     ApplicationAudit[] @relation("UserApplicationAudits")
  Contract              Contract[]
  Notification          Notification[]
  newReassignments      ReassignmentLog[]  @relation("NewAC")
  previousReassignments ReassignmentLog[]  @relation("PreviousAC")
  reassignmentsOwned    ReassignmentLog[]  @relation("ReassignmentOwner")
  adminContractor       User?              @relation("UserToAdminContractor", fields: [adminContractorId], references: [id])
  assignedUsers         User[]             @relation("UserToAdminContractor")
  company               Company?           @relation(fields: [companyId], references: [id])
  roles                 UserRole[]
  applicationsAsAc      application[]      @relation("AdminContractorApplications")
  application           application[]      @relation("UserApplications")
  applicationsAsSheq    application[]      @relation("SheqApplications")
  subcontractsAsRep     Subcontract[]      @relation("SubcontractRepresentative")
}

model application {
  id                 String              @id @default(cuid())
  status             Status              @default(primeraVez)
  workerName         String
  workerPaternal     String
  workerMaternal     String
  workerRun          String
  displayWorkerName  String
  license            License?
  licenseExpiration  DateTime?
  stateAc            StateAc
  stateSheq          StateSheq
  companyId          String?
  userId             String?
  contractId         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userAcId           String?
  userSheqId         String?
  lastReviewedAt     DateTime?
  reviewDeadline     DateTime?
  processStatus      ProcessStatus       @default(pendiente)
  audits             ApplicationAudit[]
  qr                 ApplicationQR?
  documentationFiles DocumentationFile[]
  company            Company?            @relation(fields: [companyId], references: [id])
  contract           Contract?           @relation(fields: [contractId], references: [id])
  userAc             User?               @relation("AdminContractorApplications", fields: [userAcId], references: [id])
  user               User?               @relation("UserApplications", fields: [userId], references: [id])
  userSheq           User?               @relation("SheqApplications", fields: [userSheqId], references: [id])
  activities         Activity[]          @relation("ActivityApplications")
  zones              Zone[]              @relation("ZoneApplications")
  subcontractId      String?
  subcontract        Subcontract?        @relation(fields: [subcontractId], references: [id])

  @@index([stateAc, userAcId], map: "idx_ac_review")
  @@index([stateSheq, userSheqId], map: "idx_sheq_review")
  @@index([workerRun], map: "idx_worker_run")
  @@index([companyId, status], map: "idx_company_status")
  @@index([contractId, createdAt], map: "idx_contract_date")
}

model Subcontract {
  id           String            @id @default(cuid())
  contractId   String
  subCompanyId String
  userId       String?
  createdAt    DateTime          @default(now())
  isActive     Boolean           @default(true)
  status       SubcontractStatus @default(pendiente)
  contract     Contract          @relation(fields: [contractId], references: [id])
  subCompany   Company           @relation("SubcontractCompany", fields: [subCompanyId], references: [id])
  user         User?             @relation("SubcontractRepresentative", fields: [userId], references: [id])
  applications application[]

  @@unique([contractId, subCompanyId])
  @@index([contractId])
  @@index([subCompanyId])
  @@index([userId])
}

model ApplicationQR {
  id            String      @id @default(cuid())
  applicationId String      @unique
  token         String      @unique @default(cuid())
  createdAt     DateTime    @default(now())
  expiresAt     DateTime?
  isActive      Boolean     @default(true)
  application   application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Role {
  id    String     @id @default(cuid())
  name  RoleEnum   @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model ReassignmentLog {
  id           String   @id @default(cuid())
  previousAcId String
  newAcId      String
  contractId   String
  userId       String?
  reason       String
  createdAt    DateTime @default(now())
  contract     Contract @relation(fields: [contractId], references: [id])
  newAc        User     @relation("NewAC", fields: [newAcId], references: [id])
  previousAc   User     @relation("PreviousAC", fields: [previousAcId], references: [id])
  owner        User?    @relation("ReassignmentOwner", fields: [userId], references: [id])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  message       String
  read          Boolean          @default(false)
  actionUrl     String?
  applicationId String?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model VerificationToken {
  identifier String   @id @unique
  token      String
  expires    DateTime
}

model DocumentationFile {
  id              String         @id @default(cuid())
  applicationId   String
  activityId      String?
  documentationId String?
  url             String
  type            FileType
  uploadedAt      DateTime       @default(now())
  expiresAt       DateTime?
  approvalStatus  String         @default("pending")
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  activity        Activity?      @relation(fields: [activityId], references: [id])
  application     application    @relation(fields: [applicationId], references: [id])
  documentation   Documentation? @relation(fields: [documentationId], references: [id])

  @@index([applicationId, activityId, documentationId])
}

model ApplicationAudit {
  id            String      @id @default(cuid())
  applicationId String
  action        AuditAction
  changedById   String
  changedAt     DateTime    @default(now())
  details       String?
  application   application @relation(fields: [applicationId], references: [id])
  changedBy     User        @relation("UserApplicationAudits", fields: [changedById], references: [id])
}

enum RoleEnum {
  user
  admin
  sheq
  adminContractor
  credential
}

enum SubcontractStatus {
  pendiente
  activo
  inactivo
}

enum NotificationType {
  INACTIVE_REQUEST
  REASSIGNMENT
  REQUEST_APPROVED
  REQUEST_REJECTED
  NEW_APPLICATION
  PENDING_DOCUMENTS
  CONTRACT_EXPIRING
  CREDENTIAL_READY
  NEW_USER
  SUBCONTRACT_REQUEST
  SUBCONTRACT_LINKED
  SUBCONTRACT_APPLICATION
}

enum Status {
  primeraVez
  renovacion
}

enum License {
  a1
  a2
  a3
  a4
  a5
  b
  c
  d
}

enum StateAc {
  aprobado
  pendiente
  adjuntar
}

enum StateSheq {
  aprobado
  pendiente
  rechazado
}

enum ProcessStatus {
  pendiente
  enRevision
  aprobado
  rechazado
  vencido
}

enum FileType {
  PDF
  IMG
  DOC
  OTHER
}

enum AuditAction {
  CREACION
  EDICION
  APROBACION
  RECHAZO
  OBSERVACION
  ELIMINACION
}
